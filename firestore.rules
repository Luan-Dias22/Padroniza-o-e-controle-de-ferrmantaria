rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/tools
    // Document ID: auto-generated
    // Fields:
    //   - brand: string (required)
    //   - name: string (required)
    //   - category: string (required)
    //   - description: string (required)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/standardToolLists
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - tools: list of objects (required)
    //   - isLocked: boolean (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/departments
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - standardListId: string (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/employees
    // Document ID: auto-generated
    // Fields:
    //   - employeeId: string (required)
    //   - name: string (required)
    //   - departmentId: string (required)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/assignments
    // Document ID: auto-generated
    // Fields:
    //   - employeeId: string (required)
    //   - departmentId: string (required)
    //   - assignedTools: list of objects (required)
    //   - dateAssigned: string (required)
    //   - uid: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTool(data) {
      return hasOnlyAllowedFields(['brand', 'name', 'category', 'description', 'uid']) &&
             data.brand is string && data.brand.size() > 0 && data.brand.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.description is string && data.description.size() < 1000 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidStandardToolList(data) {
      return (hasOnlyAllowedFields(['name', 'tools', 'uid']) || hasOnlyAllowedFields(['name', 'tools', 'isLocked', 'uid'])) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.tools is list && data.tools.size() <= 100 &&
             (!('isLocked' in data) || data.isLocked is bool) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidDepartment(data) {
      return (hasOnlyAllowedFields(['name', 'uid']) || hasOnlyAllowedFields(['name', 'standardListId', 'uid'])) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('standardListId' in data) || (data.standardListId is string && data.standardListId.size() < 100)) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidEmployee(data) {
      return hasOnlyAllowedFields(['employeeId', 'name', 'departmentId', 'uid']) &&
             data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.departmentId is string && data.departmentId.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidAssignment(data) {
      return hasOnlyAllowedFields(['employeeId', 'departmentId', 'assignedTools', 'dateAssigned', 'uid']) &&
             data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() < 100 &&
             data.departmentId is string && data.departmentId.size() < 100 &&
             data.assignedTools is list && data.assignedTools.size() <= 100 &&
             data.dateAssigned is string && data.dateAssigned.size() > 0 && data.dateAssigned.size() < 50 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      match /tools/{toolId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['brand', 'name', 'category', 'description', 'uid']) && isValidTool(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isDocOwner() && isValidTool(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) && isDocOwner();
      }

      match /standardToolLists/{listId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['name', 'tools', 'uid']) && isValidStandardToolList(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isDocOwner() && isValidStandardToolList(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) && isDocOwner();
      }

      match /departments/{deptId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['name', 'uid']) && isValidDepartment(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isDocOwner() && isValidDepartment(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) && isDocOwner();
      }

      match /employees/{empId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['employeeId', 'name', 'departmentId', 'uid']) && isValidEmployee(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isDocOwner() && isValidEmployee(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) && isDocOwner();
      }

      match /assignments/{assignmentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['employeeId', 'departmentId', 'assignedTools', 'dateAssigned', 'uid']) && isValidAssignment(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isDocOwner() && isValidAssignment(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) && isDocOwner();
      }
    }
  }
}
