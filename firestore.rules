rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/tools
    // Document ID: auto-generated
    // Fields:
    //   - brand: string (required)
    //   - name: string (required)
    //   - category: string (required)
    //   - description: string (required)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/standardToolLists
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - tools: list of objects (required)
    //   - isLocked: boolean (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/departments
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - standardListId: string (optional)
    //   - expectedNewcomers: number (optional)
    //   - requiredHeadcount: number (optional)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/employees
    // Document ID: auto-generated
    // Fields:
    //   - employeeId: string (required)
    //   - name: string (required)
    //   - departmentId: string (required)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/assignments
    // Document ID: auto-generated
    // Fields:
    //   - employeeId: string (required)
    //   - departmentId: string (required)
    //   - assignedTools: list of objects (required)
    //   - dateAssigned: string (required)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/collectiveLines
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/collectiveStations
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - line: string (required)
    //   - tools: list of objects (required)
    //   - uid: string (required, immutable)
    //
    // Collection: users/{userId}/stockEntries
    // Document ID: auto-generated
    // Fields:
    //   - toolId: string (required)
    //   - lineId: string (required)
    //   - quantity: number (required)
    //   - date: string (required)
    //   - uid: string (required, immutable)
    //   - type: string (required)
    //   - station: string (optional)
    //   - employeeId: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "luansold@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function canRead(userId) {
      return isOwner(userId) || userId == 'guest';
    }

    function canWrite(userId) {
      return isOwner(userId) || (userId == 'guest' && isAdmin());
    }

    function isDocOwner(userId) {
      return isOwner(userId) || (userId == 'guest' && isAdmin());
    }

    function uidUnchanged(userId) {
      return !('uid' in request.resource.data) || 
             request.resource.data.uid == request.auth.uid ||
             (userId == 'guest' && request.resource.data.uid == 'guest');
    }

    function uidNotModified(userId) {
      return !('uid' in request.resource.data) || 
             (!('uid' in resource.data) ? 
               (request.resource.data.uid == request.auth.uid || (userId == 'guest' && request.resource.data.uid == 'guest')) : 
               request.resource.data.uid == resource.data.uid);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(required, optional) {
      return request.resource.data.keys().hasAll(required) && 
             request.resource.data.keys().hasOnly(required.concat(optional));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTool(data) {
      return hasOnlyAllowedFields(['brand', 'name', 'category', 'description', 'uid'], ['price', 'id']) &&
             data.brand is string && data.brand.size() > 0 && data.brand.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.description is string && data.description.size() < 1000 &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidStandardToolList(data) {
      return hasOnlyAllowedFields(['name', 'tools', 'uid'], ['isLocked', 'id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.tools is list && data.tools.size() <= 100 &&
             (!('isLocked' in data) || data.isLocked is bool) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidDepartment(data) {
      return hasOnlyAllowedFields(['name', 'uid'], ['standardListId', 'expectedNewcomers', 'requiredHeadcount', 'id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('standardListId' in data) || (data.standardListId is string && data.standardListId.size() < 100)) &&
             (!('expectedNewcomers' in data) || (data.expectedNewcomers is number && data.expectedNewcomers >= 0)) &&
             (!('requiredHeadcount' in data) || (data.requiredHeadcount is number && data.requiredHeadcount >= 0)) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidEmployee(data) {
      return hasOnlyAllowedFields(['employeeId', 'name', 'departmentId', 'uid'], ['id']) &&
             data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.departmentId is string && data.departmentId.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidAssignment(data) {
      return hasOnlyAllowedFields(['employeeId', 'departmentId', 'assignedTools', 'dateAssigned', 'uid'], ['id']) &&
             data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() < 100 &&
             data.departmentId is string && data.departmentId.size() < 100 &&
             data.assignedTools is list && data.assignedTools.size() <= 100 &&
             data.dateAssigned is string && data.dateAssigned.size() > 0 && data.dateAssigned.size() < 50 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidCollectiveLine(data) {
      return hasOnlyAllowedFields(['name', 'uid'], ['id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidCollectiveStation(data) {
      return hasOnlyAllowedFields(['name', 'line', 'tools', 'uid'], ['id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.line is string && data.line.size() > 0 && data.line is string && data.line.size() < 100 &&
             data.tools is list && data.tools.size() <= 200 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100;
    }

    function isValidStockEntry(data) {
      return hasOnlyAllowedFields(['toolId', 'lineId', 'quantity', 'date', 'uid', 'type'], ['id', 'station', 'employeeId']) &&
             data.toolId is string && data.toolId.size() > 0 && data.toolId.size() < 100 &&
             data.lineId is string && data.lineId.size() > 0 && data.lineId.size() < 100 &&
             data.quantity is number && data.quantity != 0 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 50 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.type in ['individual', 'collective'] &&
             (!('station' in data) || (data.station is string && data.station.size() < 100)) &&
             (!('employeeId' in data) || (data.employeeId is string && data.employeeId.size() < 100));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /connection_tests/{testId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read: if canRead(userId);
      allow write: if canWrite(userId);

      match /tools/{toolId} {
        allow read: if canRead(userId);
        allow create: if canWrite(userId) && hasRequiredFields(['brand', 'name', 'category', 'description', 'uid']) && isValidTool(request.resource.data) && uidUnchanged(userId);
        allow update: if canWrite(userId) && isDocOwner(userId) && isValidTool(request.resource.data) && uidNotModified(userId);
        allow delete: if canWrite(userId) && isDocOwner(userId);
      }

      match /standardToolLists/{listId} {
        allow read: if canRead(userId);
        allow create: if canWrite(userId) && hasRequiredFields(['name', 'tools', 'uid']) && isValidStandardToolList(request.resource.data) && uidUnchanged(userId);
        allow update: if canWrite(userId) && isDocOwner(userId) && isValidStandardToolList(request.resource.data) && uidNotModified(userId);
        allow delete: if canWrite(userId) && isDocOwner(userId);
      }

      match /departments/{deptId} {
        allow read: if canRead(userId);
        allow create: if canWrite(userId) && hasRequiredFields(['name', 'uid']) && isValidDepartment(request.resource.data) && uidUnchanged(userId);
        allow update: if canWrite(userId) && isDocOwner(userId) && isValidDepartment(request.resource.data) && uidNotModified(userId);
        allow delete: if canWrite(userId) && isDocOwner(userId);
      }

      match /employees/{empId} {
        allow read: if canRead(userId);
        allow create: if canWrite(userId) && hasRequiredFields(['employeeId', 'name', 'departmentId', 'uid']) && isValidEmployee(request.resource.data) && uidUnchanged(userId);
        allow update: if canWrite(userId) && isDocOwner(userId) && isValidEmployee(request.resource.data) && uidNotModified(userId);
        allow delete: if canWrite(userId) && isDocOwner(userId);
      }

      match /assignments/{assignmentId} {
        allow read: if canRead(userId);
        allow create: if canWrite(userId) && hasRequiredFields(['employeeId', 'departmentId', 'assignedTools', 'dateAssigned', 'uid']) && isValidAssignment(request.resource.data) && uidUnchanged(userId);
        allow update: if canWrite(userId) && isDocOwner(userId) && isValidAssignment(request.resource.data) && uidNotModified(userId);
        allow delete: if canWrite(userId) && isDocOwner(userId);
      }

      match /collectiveLines/{lineId} {
        allow read: if canRead(userId);
        allow create: if canWrite(userId) && hasRequiredFields(['name', 'uid']) && isValidCollectiveLine(request.resource.data) && uidUnchanged(userId);
        allow update: if canWrite(userId) && isDocOwner(userId) && isValidCollectiveLine(request.resource.data) && uidNotModified(userId);
        allow delete: if canWrite(userId) && isDocOwner(userId);
      }

      match /collectiveStations/{stationId} {
        allow read: if canRead(userId);
        allow create: if canWrite(userId) && hasRequiredFields(['name', 'line', 'tools', 'uid']) && isValidCollectiveStation(request.resource.data) && uidUnchanged(userId);
        allow update: if canWrite(userId) && isDocOwner(userId) && isValidCollectiveStation(request.resource.data) && uidNotModified(userId);
        allow delete: if canWrite(userId) && isDocOwner(userId);
      }

      match /stockEntries/{entryId} {
        allow read: if canRead(userId);
        allow create: if canWrite(userId) && hasRequiredFields(['toolId', 'lineId', 'quantity', 'date', 'uid', 'type']) && isValidStockEntry(request.resource.data) && uidUnchanged(userId);
        allow update: if canWrite(userId) && isDocOwner(userId) && isValidStockEntry(request.resource.data) && uidNotModified(userId);
        allow delete: if canWrite(userId) && isDocOwner(userId);
      }
    }
  }
}
