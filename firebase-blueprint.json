{
  "entities": {
    "Tool": {
      "title": "Tool",
      "description": "A tool in the inventory",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["brand", "name", "category", "description", "uid"]
    },
    "StandardToolList": {
      "title": "StandardToolList",
      "description": "A predefined list of tools",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "toolId": { "type": "string" },
              "quantity": { "type": "number" }
            },
            "required": ["toolId", "quantity"]
          }
        },
        "isLocked": { "type": "boolean" },
        "uid": { "type": "string" }
      },
      "required": ["name", "tools", "uid"]
    },
    "Department": {
      "title": "Department",
      "description": "A department in the company",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "standardListId": { "type": "string" },
        "expectedNewcomers": { "type": "number" },
        "requiredHeadcount": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["name", "uid"]
    },
    "Employee": {
      "title": "Employee",
      "description": "An employee",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "name": { "type": "string" },
        "departmentId": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["employeeId", "name", "departmentId", "uid"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "A tool assignment to an employee",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "departmentId": { "type": "string" },
        "assignedTools": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "toolId": { "type": "string" },
              "quantity": { "type": "number" }
            },
            "required": ["toolId", "quantity"]
          }
        },
        "maleta_id": { "type": "string" },
        "dateAssigned": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["employeeId", "departmentId", "assignedTools", "dateAssigned", "uid"]
    },
    "Maleta": {
      "title": "Maleta",
      "description": "A maleta or TAG identification",
      "type": "object",
      "properties": {
        "codigo_tag": { "type": "string" },
        "nome": { "type": "string" },
        "setor": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativa", "Inativa", "Manutenção"] },
        "responsavel_id": { "type": "string" },
        "observacoes": { "type": "string" },
        "transfer_history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from_employee_id": { "type": "string" },
              "to_employee_id": { "type": "string" },
              "date": { "type": "string" }
            }
          }
        },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["codigo_tag", "nome", "setor", "status", "created_at", "updated_at", "uid"]
    },
    "MaletaTool": {
      "title": "MaletaTool",
      "description": "A tool linked to a maleta",
      "type": "object",
      "properties": {
        "maleta_id": { "type": "string" },
        "ferramenta_id": { "type": "string" },
        "quantidade": { "type": "number" },
        "estado": { "type": "string", "enum": ["Boa", "Danificada", "Faltando"] },
        "tag": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["maleta_id", "ferramenta_id", "quantidade", "estado", "uid"]
    },
    "CollectiveLine": {
      "title": "CollectiveLine",
      "description": "A production line for collective tools",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["name", "uid"]
    },
    "CollectiveStation": {
      "title": "CollectiveStation",
      "description": "A station in a production line",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "string" },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "toolId": { "type": "string" },
              "name": { "type": "string" },
              "category": { "type": "string" },
              "quantity": { "type": "number" }
            },
            "required": ["name", "category", "quantity"]
          }
        },
        "uid": { "type": "string" }
      },
      "required": ["name", "line", "tools", "uid"]
    },
    "StockEntry": {
      "title": "StockEntry",
      "description": "An entry of stock added to a line or department",
      "type": "object",
      "properties": {
        "toolId": { "type": "string" },
        "lineId": { "type": "string" },
        "quantity": { "type": "number" },
        "date": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["individual", "collective"] },
        "station": { "type": "string" }
      },
      "required": ["toolId", "lineId", "quantity", "date", "uid", "type"]
    },
    "MaletaCheck": {
      "title": "MaletaCheck",
      "description": "A record of a maleta check/inspection",
      "type": "object",
      "properties": {
        "maleta_id": { "type": "string" },
        "checked_by_id": { "type": "string" },
        "user_name": { "type": "string" },
        "date": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "toolId": { "type": "string" },
              "expectedQuantity": { "type": "number" },
              "observedQuantity": { "type": "number" },
              "status": { "type": "string", "enum": ["OK", "Faltando", "Danificada"] },
              "notes": { "type": "string" }
            },
            "required": ["toolId", "expectedQuantity", "observedQuantity", "status"]
          }
        },
        "observacoes": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["maleta_id", "checked_by_id", "user_name", "date", "items", "uid"]
    },
    "MaletaEvent": {
      "title": "MaletaEvent",
      "description": "An event in the life cycle of a maleta",
      "type": "object",
      "properties": {
        "maleta_id": { "type": "string" },
        "type": { "type": "string", "enum": ["creation", "edition", "transfer", "tool_addition", "tool_removal", "check"] },
        "date": { "type": "string" },
        "user_name": { "type": "string" },
        "user_id": { "type": "string" },
        "description": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["maleta_id", "type", "date", "user_name", "user_id", "description", "uid"]
    }
  },
  "firestore": {
    "users/{userId}/tools/{toolId}": {
      "schema": { "$ref": "#/entities/Tool" },
      "description": "Tools owned by the user"
    },
    "users/{userId}/standardToolLists/{listId}": {
      "schema": { "$ref": "#/entities/StandardToolList" },
      "description": "Standard tool lists owned by the user"
    },
    "users/{userId}/departments/{deptId}": {
      "schema": { "$ref": "#/entities/Department" },
      "description": "Departments owned by the user"
    },
    "users/{userId}/employees/{empId}": {
      "schema": { "$ref": "#/entities/Employee" },
      "description": "Employees owned by the user"
    },
    "users/{userId}/assignments/{assignmentId}": {
      "schema": { "$ref": "#/entities/Assignment" },
      "description": "Assignments owned by the user"
    },
    "users/{userId}/maletas/{maletaId}": {
      "schema": { "$ref": "#/entities/Maleta" },
      "description": "Maletas owned by the user"
    },
    "users/{userId}/maletaTools/{maletaToolId}": {
      "schema": { "$ref": "#/entities/MaletaTool" },
      "description": "Maleta rules linking tool and maletas owned by the user"
    },
    "users/{userId}/maletaChecks/{checkId}": {
      "schema": { "$ref": "#/entities/MaletaCheck" },
      "description": "History of maleta checks"
    },
    "users/{userId}/maletaEvents/{eventId}": {
      "schema": { "$ref": "#/entities/MaletaEvent" },
      "description": "History of events for maletas"
    },
    "users/{userId}/collectiveLines/{lineId}": {
      "schema": { "$ref": "#/entities/CollectiveLine" },
      "description": "Collective lines owned by the user"
    },
    "users/{userId}/collectiveStations/{stationId}": {
      "schema": { "$ref": "#/entities/CollectiveStation" },
      "description": "Collective stations owned by the user"
    },
    "users/{userId}/stockEntries/{entryId}": {
      "schema": { "$ref": "#/entities/StockEntry" },
      "description": "Stock entries owned by the user"
    }
  }
}
